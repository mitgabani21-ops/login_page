<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Glowing Neon Rocket with Particle Smoke (No Beam)</title>
    <style>
        :root {
            --space-bg: #04050f;
            --card-bg: rgba(10, 12, 26, 0.95);
            --neon-color: #00d2ff;
            --neon-glow: rgba(0, 210, 255, 0.4);
        }

        /* ક્લિક કર્યા પછી માત્ર RGB કલર બદલાશે */
        @keyframes neonLightGlow {
            0% {
                --neon-color: #00ff66;
                --neon-glow: rgba(0, 255, 102, 0.5);
            }
            33% {
                --neon-color: #00ccff;
                --neon-glow: rgba(0, 204, 255, 0.5);
            }
            66% {
                --neon-color: #ff3366;
                --neon-glow: rgba(255, 51, 102, 0.5);
            }
            100% {
                --neon-color: #00ff66;
                --neon-glow: rgba(0, 255, 102, 0.5);
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background-color: var(--space-bg);
            background-image: 
                radial-gradient(white, rgba(255,255,255,.15) 1.5px, transparent 40px),
                radial-gradient(white, rgba(255,255,255,.1) 1px, transparent 30px);
            background-size: 400px 400px, 250px 250px;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            perspective: 1000px;
        }

        body.light-active {
            animation: neonLightGlow 6s infinite linear;
        }

        .container {
            display: flex;
            width: 780px;
            height: 460px;
            background: transparent;
            border-radius: 24px;
            overflow: hidden;
            position: relative;
            transition: all 0.5s ease;
        }

        .shake-active { animation: shake 0.08s infinite; }
        @keyframes shake {
            0% { transform: translate(1.5px, 1.5px); }
            50% { transform: translate(-1.5px, -2px); }
            100% { transform: translate(1.5px, -1.5px); }
        }

        .space-container {
            flex: 1;
            background: #020306;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            perspective: 800px;
            padding-bottom: 20px;
            overflow: hidden;
        }

        /* 3D રોકેટ સીન */
        .rocket-3d-scene {
            width: 150px;
            height: 230px;
            position: relative;
            transform-style: preserve-3d;
            animation: rotate3D 6s infinite linear;
            transition: transform 2.5s cubic-bezier(0.6, -0.28, 0.735, 0.045);
            z-index: 3;
        }

        @keyframes rotate3D {
            0% { transform: rotateY(0deg) rotateX(-10deg); }
            100% { transform: rotateY(360deg) rotateX(-10deg); }
        }

        .launch-active {
            transform: translateY(-700px) rotateY(1440deg) scale(0.3) !important;
            animation: none !important;
        }

        /* રોકેટ કમ્પોનન્ટ્સ (નિયોન લુક) */
        .rocket-component { 
            position: absolute; 
            transform-style: preserve-3d;
            border: 2px solid var(--neon-color);
            box-shadow: 0 0 15px var(--neon-glow), inset 0 0 10px var(--neon-glow);
            transition: border 0.3s, box-shadow 0.3s;
        }

        .body-3d {
            top: 60px; left: 45px; width: 60px; height: 110px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 30px / 15px;
        }

        .nose-3d {
            top: 5px; left: 45px; width: 60px; height: 60px;
            background: rgba(255, 51, 102, 0.05);
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
        }

        .fin-left {
            top: 120px; left: 15px; width: 32px; height: 45px;
            background: rgba(255, 51, 102, 0.05);
            transform: rotateY(-45deg) translateZ(10px); 
            clip-path: polygon(100% 0, 0% 100%, 100% 100%);
        }

        .fin-right {
            top: 120px; left: 103px; width: 32px; height: 45px;
            background: rgba(255, 51, 102, 0.05);
            transform: rotateY(45deg) translateZ(10px); 
            clip-path: polygon(0 0, 0 100%, 100% 100%);
        }

        .engine-3d { 
            top: 170px; left: 60px; width: 30px; height: 12px; 
            background: rgba(255, 255, 255, 0.1);
        }

        /* નાની અગ્નિ ઇફેક્ટ */
        .fire-3d {
            top: 182px; left: 62px; width: 26px; height: 55px;
            background: linear-gradient(to bottom, #ffd32a, #ff9f43, #ff4757, transparent);
            border: none;
            box-shadow: 0 0 20px #ff9f43;
            border-radius: 50% 50% 0 50%;
            opacity: 0;
            transform-origin: top center;
        }
        .launching .fire-3d { opacity: 1; animation: flameWobble 0.08s infinite alternate; }
        @keyframes flameWobble { 0% { transform: scaleX(0.85); } 100% { transform: scaleX(1.15) scaleY(1.4); } }

        /* ==================== ઓરિજિનલ ધુમાડા કન્ટેનર ==================== */
        .smoke-container {
            position: absolute;
            bottom: 60px;
            width: 100%;
            height: 200px;
            pointer-events: none;
            z-index: 2;
        }

        .smoke-particle {
            position: absolute;
            background: radial-gradient(circle, rgba(241,242,246,0.6) 0%, rgba(116,125,140,0.1) 70%, transparent 100%);
            border-radius: 50%;
            pointer-events: none;
            transform: translate(-50%, -50%);
            animation: puffUpwards 1.8s forwards ease-out;
        }

        @keyframes puffUpwards {
            0% {
                transform: translate(-50%, 0) scale(0.4);
                opacity: 0.8;
            }
            50% {
                opacity: 0.6;
            }
            100% {
                transform: translate(var(--x-move), var(--y-move)) scale(var(--final-scale));
                opacity: 0;
            }
        }

        /* PRESS બટન */
        .press-btn {
            background: transparent;
            color: var(--neon-color);
            border: 2px solid var(--neon-color);
            padding: 10px 35px;
            font-size: 1rem;
            font-weight: bold;
            letter-spacing: 2px;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 0 15px var(--neon-glow);
            transition: all 0.3s ease;
            margin-top: 25px;
            z-index: 10;
        }

        .press-btn:hover {
            background: var(--neon-color);
            color: #000;
            box-shadow: 0 0 25px var(--neon-color);
        }

        /* લોગિન કાર્ડ */
        .login-card {
            width: 0; padding: 0;
            display: flex; flex-direction: column; justify-content: center;
            background: var(--card-bg); opacity: 0; visibility: hidden;
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .show-login .login-card { width: 50%; padding: 45px; opacity: 1; visibility: visible; }
        
        .show-login .container {
            background: var(--card-bg);
            border: 2px solid var(--neon-color);
            box-shadow: 0 0 40px var(--neon-glow);
            backdrop-filter: blur(15px);
        }
        .show-login .space-container { border-right: 2px solid var(--neon-color); }

        .login-card h2 { font-size: 2.2rem; margin-bottom: 25px; color: #fff; text-shadow: 0 0 10px var(--neon-glow); }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 0.85rem; color: #797e93; margin-bottom: 8px; }
        .input-group input {
            width: 100%; padding: 14px; background: #020306; border: 1px solid #222638;
            border-radius: 12px; color: #fff; outline: none; transition: 0.3s;
        }
        .input-group input:focus { border-color: var(--neon-color); box-shadow: 0 0 10px var(--neon-glow); }

        .login-btn {
            width: 100%; padding: 14px; background: var(--neon-color);
            border: none; border-radius: 12px; color: #000; font-size: 1rem; font-weight: bold;
            cursor: pointer; box-shadow: 0 5px 20px var(--neon-glow); transition: 0.3s;
        }
    </style>
</head>
<body>

    <div class="container" id="mainContainer">
        <div class="space-container" id="spacePanel">
            
            <!-- મોટી ત્રિકોણ બેકગ્રાઉન્ડ લાઇટ અહીંથી હટાવી દીધી છે -->
            <div class="smoke-container" id="smokeContainer"></div>
            
            <div class="rocket-3d-scene" id="rocket3D">
                <div class="rocket-component nose-3d"></div>
                <div class="rocket-component body-3d"></div>
                <div class="rocket-component fin-left"></div>
                <div class="rocket-component fin-right"></div>
                <div class="rocket-component engine-3d"></div>
                <div class="rocket-component fire-3d"></div>
            </div>

            <button class="press-btn" id="pressBtn">PRESS</button>
        </div>

        <div class="login-card">
            <h2>Space Login</h2>
            <form onsubmit="event.preventDefault(); alert('Access Granted! 🌌🚀');">
                <div class="input-group">
                    <label>Astronaut Username</label>
                    <input type="text" placeholder="Enter space ID" required>
                </div>
                <div class="input-group">
                    <label>Security Password</label>
                    <input type="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="login-btn">Launch Dashboard</button>
            </form>
        </div>
    </div>

    <script>
        const rocket3D = document.getElementById('rocket3D');
        const spacePanel = document.getElementById('spacePanel');
        const mainContainer = document.getElementById('mainContainer');
        const pressBtn = document.getElementById('pressBtn');
        const smokeContainer = document.getElementById('smokeContainer');

        let smokeInterval;

        function createSmokeParticle() {
            const particle = document.createElement('div');
            particle.classList.add('smoke-particle');
            
            particle.style.left = '50%';
            particle.style.top = '70px'; 
            
            const xMove = (Math.random() * 160 - 80) + 'px';
            const yMove = (Math.random() * 80 + 40) + 'px';
            const finalScale = (Math.random() * 3 + 2);
            
            particle.style.setProperty('--x-move', xMove);
            particle.style.setProperty('--y-move', yMove);
            particle.style.setProperty('--final-scale', finalScale);
            
            const size = (Math.random() * 20 + 15) + 'px';
            particle.style.width = size;
            particle.style.height = size;
            
            smokeContainer.appendChild(particle);
            
            setTimeout(() => {
                particle.remove();
            }, 1800);
        }

        pressBtn.addEventListener('click', function() {
            pressBtn.style.display = 'none';

            document.body.classList.add('light-active');
            spacePanel.classList.add('launching');
            mainContainer.classList.add('shake-active');

            smokeInterval = setInterval(createSmokeParticle, 30);

            setTimeout(() => {
                mainContainer.classList.remove('shake-active');
                rocket3D.classList.add('launch-active');
            }, 1200);

            setTimeout(() => {
                clearInterval(smokeInterval);
                mainContainer.classList.add('show-login');
            }, 2200);
        });
    </script>
</body>
</html>
