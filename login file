<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cute Lamp Login - Auto Multi Color</title>
    <style>
        :root {
            --bg-dark: #08080a;
            --card-bg: #111217;
            --lamp-off: #3a3b40;
            --lamp-on: #ffffff;
        }

        /* મલ્ટિ-કલર એનિમેશન - જે આપોઆપ કલર બદલશે */
        @keyframes neonGlow {
            0% {
                --neon-color: #00ff66;
                --neon-glow: rgba(0, 255, 102, 0.4);
                --neon-beam: rgba(0, 255, 102, 0.06);
            }
            25% {
                --neon-color: #00ccff;
                --neon-glow: rgba(0, 204, 255, 0.4);
                --neon-beam: rgba(0, 204, 255, 0.06);
            }
            50% {
                --neon-color: #bd00ff;
                --neon-glow: rgba(189, 0, 255, 0.4);
                --neon-beam: rgba(189, 0, 255, 0.06);
            }
            75% {
                --neon-color: #ff3366;
                --neon-glow: rgba(255, 51, 102, 0.4);
                --neon-beam: rgba(255, 51, 102, 0.06);
            }
            100% {
                --neon-color: #00ff66;
                --neon-glow: rgba(0, 255, 102, 0.4);
                --neon-beam: rgba(0, 255, 102, 0.06);
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            transition: background-color 0.3s ease;
        }

        /* મુખ્ય કન્ટેનર - વિડીયો મુજબ શરૂઆતમાં કાળું રહેશે */
        .container {
            display: flex;
            width: 750px;
            height: 430px;
            background: transparent;
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            transition: all 0.3s ease;
        }

        /* ડાબી બાજુનો લેમ્પ એરિયા */
        .lamp-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .lamp-svg {
            width: 200px;
            height: auto;
            z-index: 2;
        }

        /* લેમ્પના પાર્ટ્સ */
        .lamp-shade { fill: var(--lamp-off); transition: fill 0.3s ease; cursor: pointer; }
        .lamp-stand { fill: #2c2d33; }
        .lamp-base { fill: #1e1f24; }
        .eye { fill: #111; opacity: 0.6; }
        .blush { fill: #ff8585; opacity: 0; transition: opacity 0.3s; }
        .lamp-tongue { fill: #ff4757; display: none; }

        .cord { stroke: #555; stroke-width: 2; stroke-dasharray: 3, 3; }
        .cord-ring { fill: #666; cursor: pointer; transition: transform 0.1s, fill 0.3s; }
        .cord-group:active .cord-ring { transform: translateY(6px); }

        /* લાઇટનો બીમ (પ્રકાશ) */
        .light-beam {
            position: absolute;
            top: 35%;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 0px solid transparent;
            border-right: 0px solid transparent;
            border-bottom: 0px solid transparent;
            opacity: 0;
            transition: all 0.3s ease;
            pointer-events: none;
            z-index: 1;
        }

        /* જમણી બાજુનું લોગિન કાર્ડ - શરૂઆતમાં ગાયબ (Invisible) રહેશે */
        .login-card {
            flex: 1;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: var(--card-bg);
            border-radius: 0 20px 20px 0;
            opacity: 0;
            visibility: hidden;
            transform: scale(0.95);
            transition: all 0.4s ease;
        }

        .login-card h2 { font-size: 2rem; margin-bottom: 25px; color: #fff; }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 0.85rem; color: #888; margin-bottom: 8px; }
        .input-group input {
            width: 100%; padding: 12px; background: #08080a; border: 1px solid #252730;
            border-radius: 8px; color: #fff; outline: none; transition: border 0.3s;
        }
        .input-group input:focus { border-color: var(--neon-color); }

        /* લોગિન બટન */
        .login-btn {
            width: 100%; padding: 12px; background: var(--neon-color); border: none;
            border-radius: 8px; color: #000; font-size: 1rem; font-weight: bold;
            cursor: pointer; margin-top: 10px; box-shadow: 0 4px 15px var(--neon-glow);
            transition: background 0.3s, box-shadow 0.3s;
        }
        .form-footer { margin-top: 1.5rem; text-align: center; }
        .forgot-link { color: #888; font-size: 0.9rem; text-decoration: none; transition: 0.3s; }
        .forgot-link:hover { color: var(--neon-color); }


        /* ==================== લાઇટ ચાલુ (ON) થાય ત્યારે ==================== */
        
        body.light-on {
            background-color: #0c0d12;
            /* જ્યારે લાઇટ ચાલુ થશે ત્યારે કલર બદલવાનું એનિમેશન એક્ટિવ થશે */
            animation: neonGlow 8s infinite linear;
        }

        body.light-on .container {
            background: #111217;
            border: 1px solid var(--neon-color);
            box-shadow: 0 0 35px var(--neon-glow);
        }

        body.light-on .lamp-shade { fill: var(--lamp-on); }
        body.light-on .lamp-tongue { display: block; }
        body.light-on .blush { opacity: 1; }
        body.light-on .cord-ring { fill: var(--neon-color); }

        /* મલ્ટિ-કલર પ્રકાશનો બીમ */
        body.light-on .light-beam {
            border-left: 140px solid transparent;
            border-right: 140px solid transparent;
            border-bottom: 260px solid var(--neon-beam);
            opacity: 1;
        }

        /* લોગિન કાર્ડ પ્રગટ થશે */
        body.light-on .login-card {
            opacity: 1;
            visibility: visible;
            transform: scale(1);
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="lamp-container">
            <div class="light-beam"></div>
            <svg class="lamp-svg" viewBox="0 0 200 300" xmlns="http://www.w3.org/2000/svg">
                <path class="lamp-shade" id="shade" d="M60,90 L140,90 L160,150 L40,150 Z" />
                <circle class="eye" cx="85" cy="122" r="3.5" />
                <circle class="eye" cx="115" cy="122" r="3.5" />
                <circle class="blush" cx="74" cy="126" r="4" />
                <circle class="blush" cx="126" cy="126" r="4" />
                <path class="lamp-tongue" d="M94,127 Q100,136 106,127 Z" />
                
                <rect class="lamp-stand" x="97" y="150" width="6" height="110" />
                <ellipse class="lamp-base" cx="100" cy="260" rx="32" ry="7" />
                
                <g class="cord-group" id="switch">
                    <line class="cord" x1="135" y1="150" x2="135" y2="205" />
                    <circle class="cord-ring" cx="135" cy="205" r="6" />
                </g>
            </svg>
        </div>

        <div class="login-card">
            <h2>Welcome Back</h2>
            <form onsubmit="event.preventDefault();">
                <div class="input-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" placeholder="Enter your username">
                </div>
                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" placeholder="Enter your password">
                </div>
                <button type="submit" class="login-btn">Login</button>
            </form>
            <div class="form-footer">
                <a href="#" class="forgot-link">Forgot Password?</a>
            </div>
        </div>
    </div>

    <script>
        const btnSwitch = document.getElementById('switch');
        const shade = document.getElementById('shade');

        function toggle() {
            document.body.classList.toggle('light-on');
        }

        btnSwitch.addEventListener('click', toggle);
        shade.addEventListener('click', toggle);
    </script>
</body>
</html>
