<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Form Animation - Perfect Forward Walk</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #ff7f50; /* વીડિયો જેવો ઓરેન્જ બેકગ્રાઉન્ડ */
            overflow: hidden;
        }

        .screen-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- 1. કેરેક્ટર કન્ટેનર (માણસ સીધો ચાલે તે માટે scaleX(-1) ઉમેર્યું છે) --- */
        .character-container {
            position: absolute;
            bottom: 30%;
            display: flex;
            flex-direction: column;
            align-items: center;
            /* scaleX(-1) કરવાથી માણસનું મોઢું ચાલવાની દિશામાં (જમણી તરફ) થઈ જશે */
            transform: scaleX(-1);
            animation: walkIn 3.5s ease-in-out forwards;
        }

        .avatar {
            font-size: 80px;
            line-height: 1;
            animation: bobbing 0.5s ease-in-out infinite alternate;
        }

        .briefcase {
            font-size: 30px;
            position: absolute;
            bottom: 0;
            left: -10px; /* ફ્લિપ થયા પછી પોઝિશન સેટ કરી */
            transform-origin: bottom center;
            animation: dropBriefcase 3.5s ease-in-out forwards;
        }

        /* --- 2. રજીસ્ટ્રેશન ફોર્મ --- */
        .register-card {
            background: #ffffff;
            padding: 35px 30px;
            border-radius: 16px;
            width: 90%;
            max-width: 380px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            z-index: 10;
            
            opacity: 0;
            transform: scale(0.7) translateY(50px);
            animation: formPopup 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            animation-delay: 3.8s;
        }

        .register-card h2 {
            color: #222;
            font-size: 26px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .register-card p {
            color: #666;
            font-size: 13px;
            margin-bottom: 25px;
        }

        .input-field {
            width: 100%;
            padding: 14px;
            margin-bottom: 16px;
            border: 2px solid #eaeaea;
            border-radius: 8px;
            outline: none;
            font-size: 15px;
            transition: all 0.3s;
            background: #fcfcfc;
        }

        .input-field:focus {
            border-color: #ff7f50;
            background: #fff;
            box-shadow: 0 0 10px rgba(255, 127, 80, 0.15);
        }

        .btn-next {
            width: 100%;
            padding: 14px;
            background: #ff7f50;
            border: none;
            color: white;
            font-size: 16px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }

        .btn-next:hover {
            background: #e66738;
        }


        /* --- CSS KEYFRAMES (એનિમેશન ટાઈમલાઈન) --- */
        
        /* ડાબેથી જમણે સીધો ચાલવા માટે એનિમેશન (સાથે ફ્લિપ જાળવી રાખ્યું છે) */
        @keyframes walkIn {
            0% {
                transform: translateX(-100vw) scaleX(-1);
            }
            70% {
                transform: translateX(0) scaleX(-1);
                opacity: 1;
            }
            95% {
                opacity: 1;
            }
            100% {
                transform: translateX(0) scaleX(-1);
                opacity: 0;
                pointer-events: none;
            }
        }

        @keyframes bobbing {
            0% { transform: translateY(0); }
            100% { transform: translateY(-8px); }
        }

        @keyframes dropBriefcase {
            0% { transform: translateY(0); }
            70% { transform: translateY(0) rotate(0); }
            80% { transform: translateY(45px) rotate(10deg); }
            100% { transform: translateY(45px) rotate(0); }
        }

        @keyframes formPopup {
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="screen-wrapper">
        
        <div class="character-container">
            <div class="avatar">🚶‍♂️</div>
            <div class="briefcase">💼</div>
        </div>

        <div class="register-card">
            <h2>Register Now</h2>
            <p>Fill the form correctly to get the upcoming event ticket.</p>
            
            <form onsubmit="event.preventDefault();">
                <input type="tel" class="input-field" placeholder="Enter your mobile number" pattern="[0-9]{10}" required>
                <input type="email" class="input-field" placeholder="Enter your email address" required>
                <button type="submit" class="btn-next">NEXT</button>
            </form>
        </div>

    </div>

</body>
</html>
